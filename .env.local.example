# =============================================================================
# 찬스부동산 경매중개 — 환경변수 템플릿
# 사용법: 이 파일을 복사해 `.env.local` 로 저장한 뒤 값을 채우세요.
#   copy .env.local.example .env.local   (Windows)
#   cp .env.local.example .env.local     (macOS/Linux)
# `.env.local` 은 Git에 커밋되지 않습니다.
# =============================================================================

# --- Data provider -----------------------------------------------------------
# prisma = 로컬 SQLite(기존) / supabase = Supabase Postgres + SDK
DATA_PROVIDER=prisma

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용(절대 클라이언트에 노출 금지). Storage 업로드·관리자 작업용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Prisma를 Supabase Postgres에 직접 붙일 때(선택)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- App / Auth --------------------------------------------------------------
# 로컬 SQLite 사용 시
DATABASE_URL="file:./dev.db"
APP_BASE_URL=http://localhost:3000
ADMIN_EMAIL=admin@chance.local
ADMIN_PASSWORD=change-me-in-production
SESSION_SECRET=replace-with-long-random-string
ADMIN_AUTH_ENABLED=false

# --- Gmail (Nodemailer) ------------------------------------------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM_NAME=찬스부동산
MAIL_REPLY_TO=

# --- Solapi (문자 + 카카오 알림톡) -------------------------------------------
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
NOTIFY_KAKAO_ENABLED=false
SOLAPI_KAKAO_PF_ID=
SOLAPI_KAKAO_TEMPLATE_PROPERTY=
SOLAPI_KAKAO_TEMPLATE_AUCTION=

# --- Gemini (경매분석 리포트, 서버 전용) ------------------------------------
GEMINI_API_KEY=
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_BLOG_URL=
