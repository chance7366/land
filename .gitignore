# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env / secrets — never commit
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# keep templates
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma local sqlite
/prisma/*.db
/prisma/*.db-journal
/prisma/dev.db*

# uploaded property/auction images (local disk)
/public/uploads/properties/*
!/public/uploads/properties/.gitkeep
/storage/uploads/properties/*
!/storage/uploads/properties/.gitkeep
/storage/uploads/auctions/*
!/storage/uploads/auctions/.gitkeep

# OS / IDE / local tooling
.idea/
.vscode/*
!.vscode/extensions.json
.cursor/
.playwright-mcp/

# logs & temp
*.log
tmp/
temp/

# local design dumps / office drafts at repo root (not app assets)
/*.png
/*.docx
/*.doc
news-sidebar-check.yml
